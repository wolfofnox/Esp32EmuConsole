[
    {
        "uri": "/api/hello", // (Required) URI to match
        "method": "GET", // (Required) HTTP method to match
        "response": { // (Optional) response, if not present, response asked at runtime
            "statusCode": 200, // (Required) HTTP status code
            "contentType": "text/plain", // (Optional) Content-Type header
            "headers": { // (Optional) Additional headers
                "Cache-Control": "no-cache"
            },
            "body": "Hello, World!" // (Optional) Response body
        }
    },
    { // Example of a rule without a predefined response
        "uri": "/api/noresp",
        "method": "GET"
    },
    { // WebSocket echo example - echoes back received messages
        "type": "websocket",
        "path": "/ws",
        "behavior": "echo"
    },
    { // WebSocket static response example - returns a fixed message
        "type": "websocket",
        "path": "/ws/sensor",
        "behavior": "static",
        "webSocketResponse": "{\"temp\":25.5,\"humidity\":60}"
    }
]