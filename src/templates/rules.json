[
    {
        "uri": "/api/hello",
        "method": "GET",
        "response": {
            "http": {
                "statusCode": 200,
                "contentType": "text/plain",
                "headers": {
                    "Cache-Control": "no-cache"
                },
                "body": "Hello, World!"
            }
        }
    },
    {
        "uri": "/api/noresp",
        "method": "GET",
        "response": {
            "http": {
                "statusCode": 501,
                "body": "No response defined"
            }
        }
    },
    {
        "uri": "/ws",
        "response": {
            "ws": {
                "behavior": "echo"
            }
        }
    },
    {
        "uri": "/ws/sensor",
        "response": {
            "ws": {
                "behavior": "static",
                "text": "{\"temp\":25.5,\"humidity\":60}"
            }
        }
    },
    {
        "uri": "/ws/interval",
        "response": {
            "ws": {
                "behavior": "interval",
                "intervalMs": 1000,
                "text": "{\"timestamp\":\"periodic_update\"}"
            }
        }
    },
    {
        "uri": "/ws/binary",
        "response": {
            "ws": {
                "behavior": "static",
                "binary": "48656C6C6F20576F726C64"
            }
        }
    }
]